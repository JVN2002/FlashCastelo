# ============================================
# CONFIGURAÇÃO - FLASH CASTELO PAYMENT SERVER
# ============================================
# IMPORTANTE: Criar arquivo .env com essas variáveis
# NUNCA comitar este arquivo em produção!

# NODE Environment
NODE_ENV=development
PORT=3000

# ============================================
# CREDENCIAIS MERCADO PAGO POINT
# ============================================

# URL base da API Mercado Pago
MP_API_URL=https://api.mercadopago.com

# Access token da conta Mercado Pago
MP_ACCESS_TOKEN=COLE_AQUI_SEU_ACCESS_TOKEN

# Device ID da maquininha Point (obrigatório para criar payment intent)
MP_POINT_DEVICE_ID=COLE_AQUI_SEU_DEVICE_ID

# Opcional: POS/Store (útil para listar dispositivos)
MP_POS_ID=
MP_STORE_ID=

# ============================================
# DADOS DA LOJA
# ============================================

STORE_NAME=Flash Castelo - Adega e Tabacaria
STORE_ADDRESS=Av. Humberto de Alencar Castelo Branco, 3911 - São Bernardo do Campo
STORE_CNPJ=--
STORE_EMAIL=adegaflashcastelo@gmail.com
STORE_PHONE=(11) 98791-4958

# ============================================
# CONFIGURAÇÕES DE PAGAMENTO
# ============================================

# Valor máximo por transação (centavos)
MAX_TRANSACTION_VALUE=9999999

# Máximo de parcelas permitidas
MAX_INSTALLMENTS=12

# Timeout de conexão com Mercado Pago (ms)
MP_TIMEOUT=30000

# Janela de espera de confirmação da maquininha (ms)
MP_POINT_POLL_TIMEOUT=90000
MP_POINT_POLL_INTERVAL=3000

# ============================================
# MÓDULO FISCAL (FOCUS NFE)
# ============================================

# Ambiente fiscal padrão do backend: homologacao | producao
FOCUS_NFE_AMBIENTE=homologacao

# Chaves de API por ambiente
FOCUS_NFE_API_KEY_HOMOLOGACAO=
FOCUS_NFE_API_KEY_PRODUCAO=

# URLs base por ambiente
FOCUS_NFE_BASE_URL_HOMOLOGACAO=https://homologacao.focusnfe.com.br
FOCUS_NFE_BASE_URL_PRODUCAO=https://api.focusnfe.com.br

# Timeout de requisição fiscal (ms)
FOCUS_NFE_TIMEOUT_MS=30000

# CNPJ obrigatório do emitente (somente dígitos)
FOCUS_NFE_REQUIRED_EMITENTE_CNPJ=

# ============================================
# LOGGING E DEBUG
# ============================================

# Níveis: debug, info, warn, error
LOG_LEVEL=info

# Salvar logs em arquivo?
SAVE_LOGS=false

# Pasta para logs
LOG_DIR=./logs

# ============================================
# SEGURANÇA
# ============================================

# Chave para CORS (domínios permitidos)
# Separados por vírgula
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000

# Habilitar HTTPS?
USE_HTTPS=false

# Caminho do certificado SSL (se USE_HTTPS=true)
SSL_CERT_PATH=./certs/server.crt
SSL_KEY_PATH=./certs/server.key

# ============================================
# BANCO DE DADOS (Se adicionar futuramente)
# ============================================

# DATABASE_URL=mongodb://localhost:27017/flashcastelo
# DATABASE_HOST=localhost
# DATABASE_PORT=27017
# DATABASE_NAME=flashcastelo
# DATABASE_USER=admin
# DATABASE_PASSWORD=senha123

# ============================================
# INTEGRAÇÃO COM OUTROS SISTEMAS
# ============================================

# Para relatórios automatizados
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=seu_email@gmail.com
EMAIL_SMTP_PASSWORD=sua_senha

# Para webhook de notificações
WEBHOOK_URL=https://seu-site.com/webhooks/pagamento

# ============================================
# MODO DE DESENVOLVIMENTO
# ============================================

# Simular pagamentos (sem Mercado Pago real)?
SIMULATE_PAYMENTS=true

# Simular com sucesso sempre? (true/false)
SIMULATE_SUCCESS_RATE=0.95

# Delay simulado de processamento (ms)
SIMULATE_DELAY=1000
